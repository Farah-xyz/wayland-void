{
    // ======================= Waybar configuration =============================== //
    "modules-left": ["custom/launcher", "river/tags", "custom/wf-recorder", "river/mode"],
    "modules-center": ["clock"],
    "modules-right": ["idle_inhibitor", "pulseaudio", "backlight", "battery", "tray", "custom/power"],

    // ======================= Modules configuration =============================== //
    // == River Tags & Icons ==/
    "river/tags": {
        "num-tags": 5,
        "tag-labels" : ["┬╣õĖĆ", "┬▓õ║ī", "┬│õĖē", "Ōü┤Õøø", "ŌüĄõ║ö", "ŌüČÕģŁ", "ŌüĘõĖā", "ŌüĖÕģ½", "Ōü╣õ╣Ø", "ÕŹü"]
    },
    //== Show Mode River WM ==//
    "river/mode": {
        "format": "mode: {}",
    },
    // == Show Language Keyboard in River WM ==//
    "river/language": {
        "format": "’ä£  {} ",
        "format-en": "us",
        "format-ar": "ar",
        "keyboard-name": "at-translated-set-2-keyboard"
    },
    // == Show Status Idle ==//
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü« ",
            "deactivated": "’ü░ "
        }
    },
    // == Show System Tray ==//
    "tray": {
        "spacing": 10
    },
    // == Show Clock ==//
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
         "format": "{:%H:%M} ’ĆŚ ",
         "format-alt": "{:%A, %B %d, %Y} ’ē│ "
    },
    // == Show Light ==//
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["’åģ ", "’äæ "],
        "on-scroll-up": "doas brightnessctl set +5%",
        "on-scroll-down": "doas brightnessctl set 5%-"
    },
    // == Show Level Battery ==//
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "tooltip-format": "{timeTo}, {capacity}%",
        "format-charging": "’ć”  {capacity}%",
        "format-plugged": "’ć” ",
        "format-alt": "{time} {icon}",
        "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "],
    },
    // == Show Volume ==//
    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon}’Ŗö {volume}% {format_source}",
        "format-bluetooth-muted": "’Ć” ’Ŗö {volume}% {format_source}",
        "format-source": "’ä░ ",
        "format-source-muted": "’ä▒ ",
        "format-muted": "’Ć”  {format_source}",
        "format-icons": {
            "headphone": "’Ćź ",
            "hands-free": "’¢É ",
            "headset": "’¢É ",
            "phone": "’éĢ ",
            "portable": "’éĢ ",
            "car": "’å╣ ",
            "default": ["’Ć¦ ", "’Ć© "]
        },
        "tooltip-format": "{desc}, {volume}%",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click-middle": "pavucontrol"
    },
    // == Fuzzel Launcher Applications ==//
    "custom/launcher":{
        "format": "’ī« ",
        "on-click": "fuzzel",
        "on-click-right": "pkill fuzzel"
    },
    // == Show Screen Recorder ==//
    "custom/wf-recorder": {
        "format": "’ĆĮ ",
        "return-type": "json",
        "interval": 1,
        "exec": "echo '{\"class\": \"recording\"}'",
        "exec-if": "pgrep wf-recorder",
        "on-click": "killall -s SIGINT wf-recorder && notify-send \"’ŖŹ  Recording Complete\"",
      },
    // == Show Power Manager ==//
    "custom/power": {
          "format": " ’Ćæ {}",
          "on-click": "bash ~/.config/river/scripts/powerMenu.sh"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": "true"
        },
},
